[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060

; AUTH (unique names)
[1001-auth]
type=auth
auth_type=userpass
username=1001
password=pass123
realm=*

[1002-auth]
type=auth  
auth_type=userpass
username=1002
password=pass123
realm=*

; AOR (match endpoint names)
[1001]
type=aor
max_contacts=10

[1002]
type=aor
max_contacts=10

; ENDPOINTS reference auth by name
[1001]
type=endpoint
transport=transport-udp
context=ai-inbound
disallow=all
allow=ulaw,alaw,g722
auth=1001-auth
aors=1001
rtp_symmetric=yes
force_rport=yes
direct_media=no
ice_support=yes

[1002]
type=endpoint
transport=transport-udp
context=ai-inbound
disallow=all
allow=ulaw,alaw,g722
auth=1002-auth
aors=1002
rtp_symmetric=yes
force_rport=yes
direct_media=no
ice_support=yes

; AI AGENT AUTH & AOR
[ai-agent-auth]
type=auth
auth_type=userpass
username=ai-agent
password=aiagentpass

[ai-agent]
type=aor
max_contacts=1

; THEN your [ai-agent] endpoint
[ai-agent](+)
type=endpoint
transport=transport-udp
context=default
disallow=all
allow=slin16
auth=ai-agent-auth
aors=ai-agent
rtp_symmetric=yes

